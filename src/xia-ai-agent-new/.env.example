# ==========================================
# 环境变量配置模板
# 使用方式：复制此文件为 .env 并填入真实的 API Key
#      cp .env.example .env
# 注意：.env 文件已在 .gitignore 中排除，不会被提交到 Git
# ==========================================

# ---------- 阿里云百炼 / DashScope ----------
# 申请地址：https://bailian.console.aliyun.com/
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# ---------- SearchAPI 搜索服务 ----------
# 申请地址：https://www.searchapi.io/
SEARCH_API_KEY=your_search_api_key_here

# ---------- 高德地图 MCP 服务 ----------
# 申请地址：https://lbs.amap.com/
# 注意：MCP stdio 模式的 JSON 配置不支持 Spring 占位符，
#       需在 src/main/resources/mcp-servers.json 中配置真实 Key
AMAP_MAPS_API_KEY=your_amap_api_key_here

# ---------- Pexels 图片搜索 ----------
# 申请地址：https://www.pexels.com/api/
PEXELS_API_KEY=your_pexels_api_key_here

# ---------- PostgreSQL 数据库（PgVector）----------
DB_HOST=1.13.194.211
DB_PORT=5432
DB_NAME=yu_ai_agent
DB_USERNAME=xiachao
DB_PASSWORD=your_db_password_here
